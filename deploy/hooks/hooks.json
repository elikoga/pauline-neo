[
  {
    "id": "deploy-preview",
    "execute-command": "/etc/webhook/deploy-preview.sh",
    "command-working-directory": "/",
    "pass-arguments-to-command": [
      {"source": "payload", "name": "branch"},
      {"source": "payload", "name": "image"}
    ],
    "response-message": "deploying preview",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "REPLACE_WITH_WEBHOOK_SECRET",
        "parameter": {"source": "header", "name": "X-Webhook-Secret"}
      }
    }
  },
  {
    "id": "teardown-preview",
    "execute-command": "/etc/webhook/teardown-preview.sh",
    "command-working-directory": "/",
    "pass-arguments-to-command": [
      {"source": "payload", "name": "branch"}
    ],
    "response-message": "tearing down preview",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "REPLACE_WITH_WEBHOOK_SECRET",
        "parameter": {"source": "header", "name": "X-Webhook-Secret"}
      }
    }
  },
  {
    "id": "deploy-prod",
    "execute-command": "/etc/webhook/deploy-prod.sh",
    "command-working-directory": "/",
    "pass-arguments-to-command": [
      {"source": "payload", "name": "image"}
    ],
    "response-message": "deploying production",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "REPLACE_WITH_WEBHOOK_SECRET",
        "parameter": {"source": "header", "name": "X-Webhook-Secret"}
      }
    }
  }
]
